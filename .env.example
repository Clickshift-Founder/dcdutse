# ============================================================
#  DC CONNECT — ENVIRONMENT CONFIG
#  Copy this file to ".env" and fill in your values.
#  Then in Vercel: Project Settings → Environment Variables,
#  add the same VITE_* values there.
# ============================================================

# ---- SUPABASE (shared cloud database) ----
# Get these from Supabase Dashboard → Project Settings → API
# After running supabase-setup.sql in the SQL editor.
# WITHOUT these, the app runs in browser-only demo mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- BACKEND (optional: only for AUTOMATIC messaging) ----
# Point the frontend at your backend server (on your VPS).
# Leave blank to use manual tap-to-send (free, no backend).
VITE_API_URL=

# ============================================================
#  The values below go in the BACKEND .env (server/index.js),
#  NOT the frontend. Only needed for automatic messaging.
# ============================================================

PORT=4000

# ---- Option A: WhatsApp Cloud API (Meta) — best for Nigeria ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ---- Option B: Twilio (SMS or WhatsApp) ----
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_SMS_FROM=+1234567890
TWILIO_WHATSAPP_FROM=+14155238886

# ---- Email (optional) ----
# For automatic emails via the backend (e.g. SendGrid, Resend, SMTP).
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=hello@dcdutse.org

# ============================================================
#  EMAILJS (optional: send email straight from the browser,
#  no backend needed). Get from https://emailjs.com
#  If set, the frontend can send emails client-side.
# ============================================================
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
