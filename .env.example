# ============================================================
#  DC CONNECT — ENVIRONMENT CONFIG
#  Copy this file to ".env" and fill in your values.
#  The frontend works WITHOUT any of this (offline mode).
#  These are only needed for the optional backend + auto-messaging.
# ============================================================

# Backend server port
PORT=4000

# Point the frontend at your backend (leave blank for offline-only mode)
# Set in a separate frontend .env as: VITE_API_URL=http://your-vps-ip:4000
VITE_API_URL=

# ---- Option A: WhatsApp Cloud API (Meta) ----
# Get these from https://developers.facebook.com (WhatsApp Business)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ---- Option B: Twilio (SMS or WhatsApp) ----
# Get these from https://console.twilio.com
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_SMS_FROM=+1234567890
TWILIO_WHATSAPP_FROM=+14155238886
